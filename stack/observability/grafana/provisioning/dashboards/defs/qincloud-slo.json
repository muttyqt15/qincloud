{
  "uid": "qincloud-slo",
  "title": "QinCloud — SLO",
  "tags": ["qincloud", "slo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-30d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "app",
        "label": "app",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(qincloud_app_up, app)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Availability SLO — target 99.5% over 30d",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Current availability (5m SLI)",
      "description": "qincloud:sli_availability:ratio_rate5m from the SLO recording rules. Red under the 99.5% target. Empty until the recording rules have history — see the raw fallback stat.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0.995 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "qincloud:sli_availability:ratio_rate5m{app=~\"$app\"}",
          "legendFormat": "{{app}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "30-day error budget remaining",
      "description": "Fraction of the 30-day 0.5% error budget still unspent: 1 - (1 - availability_30d) / (1 - 0.995), clamped at 100%. 30-day availability is avg_over_time of the 5m SLI (no dedicated 30d recording rule). Negative = budget blown; red under 20%.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "green", "value": 50 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "clamp_max(100 * (1 - (1 - avg_over_time(qincloud:sli_availability:ratio_rate5m{app=~\"$app\"}[30d])) / (1 - 0.995)), 100)",
          "legendFormat": "{{app}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Raw app up — fallback (qincloud_app_up)",
      "description": "Live up/down straight from qincloud_app_up (the controld exporter), independent of the SLI recording rules. Guarantees the board shows real state even before the recording rules have accumulated any history.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "down", "color": "red" }, "1": { "text": "up", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "qincloud_app_up{app=~\"$app\"}",
          "legendFormat": "{{app}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Availability trend (1h SLI)",
      "description": "qincloud:sli_availability:ratio_rate1h over the window. The line marks the 99.5% SLO target — dips below it are burning error budget.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never",
            "thresholdsStyle": { "mode": "line" }
          },
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0.995 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "qincloud:sli_availability:ratio_rate1h{app=~\"$app\"}",
          "legendFormat": "{{app}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Error-budget burn rate (multiwindow)",
      "description": "How fast the 0.5% budget is being spent, at each SLI window: (1 - availability) / (1 - 0.995). 1x burns the whole 30-day budget in exactly 30 days. Lines mark 1x (burning budget) and 14.4x (Google fast-burn: 2% of budget in 1h).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 0,
            "showPoints": "never",
            "thresholdsStyle": { "mode": "line" }
          },
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 14.4 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(1 - qincloud:sli_availability:ratio_rate5m{app=~\"$app\"}) / (1 - 0.995)",
          "legendFormat": "{{app}} · 5m"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(1 - qincloud:sli_availability:ratio_rate1h{app=~\"$app\"}) / (1 - 0.995)",
          "legendFormat": "{{app}} · 1h"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(1 - qincloud:sli_availability:ratio_rate6h{app=~\"$app\"}) / (1 - 0.995)",
          "legendFormat": "{{app}} · 6h"
        },
        {
          "refId": "D",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(1 - qincloud:sli_availability:ratio_rate3d{app=~\"$app\"}) / (1 - 0.995)",
          "legendFormat": "{{app}} · 3d"
        }
      ]
    }
  ]
}
