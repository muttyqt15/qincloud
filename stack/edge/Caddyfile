# stack/edge/Caddyfile — first-boot seed for the QinCloud edge.
# M4: controld owns routes via the admin API, and caddy runs with --resume
# (see compose.yml): after the first API change, the autosaved JSON config is
# what boots — this file no longer applies on restart. Editing it requires an
# explicit `caddy reload --config /etc/caddy/Caddyfile`, which drops all
# controld-programmed routes (re-deploy each app afterwards).
{
	# Admin API on a unix socket only: app_net is shared with tenant apps
	# (M6), and any container on that bridge could otherwise POST /load and
	# reprogram the edge. controld (M4) must reach it via a shared mount of
	# /run/caddy/admin.sock — never over a network. The socket gets its own
	# dir so the caddy_admin volume can be mounted at /run/caddy without
	# shadowing everything else in /run.
	admin unix//run/caddy/admin.sock

	# Runtime logs as JSON on stdout — Loki scrapes docker logs (M3).
	log {
		output stdout
		format json
	}
}

# The platform domain. This site block is what creates the :443 server and
# turns on auto-TLS (Let's Encrypt); controld inserts each app's route into
# that same :443 server, and Caddy auto-provisions a cert per app hostname
# when the route lands (needs the app's DNS record pointing here first).
sparboard.com {
	log {
		output stdout
		format json
	}

	respond "qincloud edge ok" 200
}

# The controld dashboard, public behind Cloudflare + edge basic auth
# (operator decision 2026-07-06). The dashboard drives docker.sock, so this
# site block is a root-equivalent door; caddy reaches controld over admin_net
# (caddy + controld + prometheus only). The TS_IP:8600 binding stays as the
# no-auth tailnet path.
# dash.sparboard.com: the controld dashboard, public behind Cloudflare + edge
# basic auth. Full rationale lives in runbooks/gotchas/dashboard.md.
# Two traps learned here, both silent (adapt succeeds, gate just missing):
#  1. A named matcher must be POSITIVE (@cf remote_ip), not negated
#     (not remote_ip): a "not remote_ip" matcher collides with the :2019
#     block's remote_ip matcher in Caddy 2.10's adapter and one is dropped.
#  2. Keep comments in this block plain ASCII (no backtick, no brace/dollar):
#     those chars in a comment make the lexer swallow following directives.
dash.sparboard.com {
	log {
		output stdout
		format json
	}

	# Origin serves a self-signed cert; the zone SSL mode is Full so Cloudflare
	# accepts it. No ACME here (HTTP-01 cannot pass the orange-cloud proxy).
	tls internal

	# Only Cloudflare edge IPs reach the auth+proxy; the public origin IP,
	# hit directly (bypassing Cloudflare's WAF/rate-limiting), falls through to
	# 404 before any bcrypt. Ranges from cloudflare.com/ips (refreshed
	# 2026-07-06).
	@cf remote_ip 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
	handle @cf {
		basic_auth {
			admin {$DASH_PASSWORD_HASH}
		}
		reverse_proxy qincloud-controld:8600
	}
	handle {
		respond 404
	}
}

# HTTP side: keep the health endpoint for the container healthcheck, bounce
# everything else to HTTPS. Explicitly claiming :80 means Caddy does NOT
# generate its own redirect server; this one block is the whole HTTP story.
# ACME HTTP-01 challenges never reach these routes — Caddy intercepts
# /.well-known/acme-challenge/ ahead of the configured handlers.
:80 {
	log {
		output stdout
		format json
	}

	handle /healthz {
		respond 200
	}
	handle {
		redir https://{host}{uri} 308
	}
}

# Metrics-only listener for Prometheus. Caddy is on app_net (to proxy tenant
# apps) AND admin_net, and this listener binds every interface — so without a
# guard any tenant container on app_net could scrape it and enumerate every
# Metrics for Prometheus. Listens on all interfaces (plain :2019, no matcher):
# a second remote_ip matcher here collides with dash's @cf matcher in Caddy
# 2.10's adapter and one silently drops, and binding to a fixed admin_net IP
# proved fragile (see runbooks/gotchas/dashboard.md). RESIDUAL: a tenant app on
# app_net can scrape these edge metrics (co-tenant hostnames + upstream dials —
# a minor info leak, no auth/traffic exposure). Revisit if app_net ever carries
# untrusted tenants; the real fix is a Caddy build with the metrics endpoint on
# a dedicated admin listener.
:2019 {
	handle /metrics {
		metrics
	}
	handle {
		respond 404
	}
}
