# Copy to .env on the box and fill in. Never commit .env.

# Cloudflare R2 — offsite backups (M2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=qincloud-backups

# Discord — Alertmanager notifications (M3)
# webhook itself goes in secrets/discord_webhook (gitignored), not here
DISCORD_WEBHOOK_URL=

# Tailscale IP of the box — admin UIs bind to this (M3+)
TS_IP=
