# Copy to .env on the box and fill in. Never commit .env.

# Cloudflare R2 — offsite backups (M2). Account ID is the hex subdomain of the
# S3 endpoint; the two keys come from an R2 API token (Object Read & Write,
# scoped to the bucket).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Discord — Alertmanager notifications (M3)
# webhook itself goes in secrets/discord_webhook (gitignored), not here
DISCORD_WEBHOOK_URL=

# Tailscale IP of the box — admin UIs bind to this (M3+)
TS_IP=

# stack/data (M2)
POSTGRES_USER=
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# stack/controld (M4) — controld's own database, e.g.
# postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@qincloud-postgres:5432/controld?sslmode=disable
CONTROLD_DSN=

# stack/observability (M3)
GRAFANA_ADMIN_PASSWORD=
# postgres-exporter DSN, e.g. postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@postgres:5432/postgres?sslmode=disable
POSTGRES_EXPORTER_DSN=
